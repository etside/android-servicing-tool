<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1565C0"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Android Servicing Tool"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="License Administration"
                android:textColor="#BBDEFB"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card: License Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="License Details"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User / Customer Name"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <EditText
                android:id="@+id/inputUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. John Doe"
                android:inputType="textPersonName"
                android:background="@android:color/white"
                android:padding="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expiry Date"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <EditText
                android:id="@+id/inputExpiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="YYYY-MM-DD"
                android:inputType="text"
                android:background="@android:color/white"
                android:padding="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Features (comma-separated)"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <EditText
                android:id="@+id/inputFeatures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="frp_bypass,knox_bypass,diag,full_chain"
                android:inputType="text"
                android:background="@android:color/white"
                android:padding="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available: frp_bypass · knox_bypass · diag · mtk_brom · lockscreen · imei · full_chain"
                android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/buttonGenerate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Generate License Token"
                android:backgroundTint="#1976D2"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card: Output -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Generated Token"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <Button
                    android:id="@+id/buttonCopy"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Copy"
                    android:textSize="11sp"
                    android:backgroundTint="#E8EAF6"
                    android:textColor="#1976D2" />
            </LinearLayout>

            <TextView
                android:id="@+id/outputLicense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:padding="12dp"
                android:background="#0D1117"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textIsSelectable="true"
                android:text="Token will appear here…" />
        </LinearLayout>

        <!-- Card: Approval Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Approval"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/inputLicenseToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Paste license token to verify"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:background="@android:color/white"
                android:padding="10dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/buttonVerify"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Verify &amp; Approve"
                android:backgroundTint="#16A34A"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/outputVerify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:padding="10dp"
                android:background="#F0FDF4"
                android:textColor="#166534"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
